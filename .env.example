OPENAI_API_KEY=sk-...
# Model used for scene-brief normalization (gpt-4o-mini is the default)
OPENAI_MODEL=gpt-4o-mini
PORT=3001

# Backoffice integration — set both to enable per-category gating.
# Leave unset to show the visualizer on all collections (default/demo mode).
BACKOFFICE_URL=http://localhost:3002
SHOP_DOMAIN=yourstore.myshopify.com
